class SummaryRanges:

    def __init__(self):
        self.arr = []    

    def addNum(self, value: int) -> None:
        
        ind = self.bi_search(value)
        remove_left = False
        remove_right = False
        if ind == -1 or ind == len(self.arr) or (self.arr[ind] != value and (ind % 2 == 1)):
            remove_right = ind + 1 < len(self.arr) and self.arr[ind + 1] == value + 1
            remove_left = ind >= 0 and self.arr[ind] == value - 1
            if remove_right and remove_left:
                del self.arr[ind]
                del self.arr[ind]
            elif remove_right:
                del self.arr[ind + 1]
                self.arr.insert(ind + 1, value)
            elif remove_left:
                del self.arr[ind]
                self.arr.insert(ind, value)
            else:
                self.arr.insert(ind + 1, value)
                self.arr.insert(ind + 1, value)

    def getIntervals(self) -> List[List[int]]:
        return [[self.arr[i], self.arr[i + 1]] for i in range(0, len(self.arr), 2)]

    def bi_search(self, x):
        
        low = 0
        high = len(self.arr) - 1
        mid = 0
    
        while low <= high:
    
            mid = (high + low) // 2
    
            if self.arr[mid] < x:
                low = mid + 1
    
            elif self.arr[mid] > x:
                high = mid - 1
            else:
               return mid
    
        return high



