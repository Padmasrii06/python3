class Solution:
    def canPartition(self, nums: List[int]) -> bool:
        s = sum(nums)
        if s & 1:
            return False
        s = s >> 1
        dp = [False] * (s + 1)
        dp[0] = True
        for i in nums:
            for j in range(s, i - 1, -1):
                if not dp[j]:
                    dp[j] = dp[j - i]
                if dp[s]:
                    return True
        return False
