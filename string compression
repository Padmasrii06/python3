class Solution:
    def compress(self, chars: List[str]) -> int:
        result=[]
        count=1
        for i in range(len(chars)):
            if i+1<len(chars)  and chars[i]==chars[i+1]:
                count+=1
            else:
                result.append(chars[i])
                if count>1:
                    for d in str(count):
                        result.append(d)
                count=1
        chars[:]=result
        len(result)
