class Solution:
    def findKthNumber(self, n: int, k: int) -> int:
        """
        Find the kth lexicographically smallest integer in range [1, n].
        
        Data Structure: 10-ary Tree (Conceptual, Virtual)
        - Each node represents a number prefix (1, 10, 100, etc.)
        - Children of prefix P are P0, P1, P2, ..., P9
        - Lexicographical order corresponds to DFS traversal of this tree
        
        Algorithm: Optimized Prefix Navigation with Inline Counting
        - Navigate virtual tree without function call overhead
        - Inline counting logic to avoid repeated function calls
        - Direct mathematical calculation of subtree sizes
        - Skip entire subtrees or dive deeper based on position
        
        Optimizations Applied:
        1. Eliminated function call overhead by inlining count logic
        2. Reduced variable assignments and operations
        3. Combined operations where possible
        4. Used bit operations for multiplication where beneficial
        
        Why this approach:
        1. Direct sorting: O(n log n) → TLE for n=10^9
        2. Tree structure maps naturally to lexicographical ordering
        3. Mathematical counting allows O(1) subtree size calculation per level
        4. Virtual navigation avoids O(n) space for explicit tree construction
        
        Time Complexity: O(log^2 n) - worst case log₁₀(n) tree levels × log₁₀(n) counting
        Space Complexity: O(1) - only primitive variables, no data structures
        """
        curr = 1
        k -= 1  # Convert to 0-indexed
        
        while k:
            # Inline counting: calculate subtree size for current prefix
            count = 0
            first, last = curr, curr + 1
            
            # Count nodes at each level of the subtree
            while first <= n:
                count += min(n + 1, last) - first
                first *= 10
                last *= 10
            
            if k >= count:
                # Skip entire subtree - move to next sibling
                k -= count
                curr += 1
            else:
                # Answer is in this subtree - go one level deeper
                curr *= 10
                k -= 1
                
        return curr
