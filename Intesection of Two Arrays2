from collections import Counter
class Solution:
    def intersect(self, nums1: List[int], nums2: List[int]) -> List[int]:
        result = []
        # for i in nums1[:] :
            # if i in nums2 :
            #     result.append(i)
            #     nums1.remove(i)
            #     nums2.remove(i)
        # temp = nums2[:]
        # for i in nums1 :
        #     if i in temp :
        #         result.append(i)
        #         temp.remove(i)
        counts1 = Counter(nums1)
        for num in nums2 :
            if counts1.get(num,0) > 0 :
                result.append(num)
                counts1[num] -= 1
        return result
