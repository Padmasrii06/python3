# - IDEAS
#   - Similar to LFU Cache and Maximum Frequency Stack.
#   - Counts is similar to frequency
#   - Key issue, we need to track min_count in case of decrementing, an issue we didn't have with LFU.
#       - to handle this, we tweak doubly linked list so each node stores all keys with that count.
#   - Implementation using doubly-linked-list to track keys for each count, hashmap from key to node.
#       - 
from collections import defaultdict

class CountNode:
    def __init__(self, count=0, keys=None):
        self.count = count
        self.keys = set() if keys is None else keys
        self.prev = None
        self.next = None

class AllOne:
    def __init__(self):
        # initialize dummy head and dummy tail nodes with sentinel counts
        self.head = CountNode(float("-inf"))
        self.tail = CountNode(float("inf"))
        self.head.next = self.tail
        self.tail.prev = self.head
        self.key_to_node = {}

    def inc(self, key: str) -> None:
        if key not in self.key_to_node:
            if self.head.next.count != 1:
                self._add_node(self.head, CountNode(1))
            self.head.next.keys.add(key)
            self.key_to_node[key] = self.head.next
        else:
            node = self.key_to_node[key]
            new_count = node.count + 1
            node.keys.remove(key)
            if node.next.count != new_count:
                self._add_node(node, CountNode(new_count))
            node.next.keys.add(key)
            self.key_to_node[key] = node.next
            if not node.keys:
                self._remove_node(node.prev, node)

    def dec(self, key: str) -> None:
        # remove key from node's keys set
        # move key to a node corresponding to new_count if it exists, or create new node
        # point key_to_node to the new node
        node = self.key_to_node[key]
        node.keys.remove(key)
        prev_node = node.prev
        if not node.keys:
            self._remove_node(prev_node, node)
        new_count = node.count - 1
        if new_count > 0:
            if prev_node.count == new_count:
                prev_node.keys.add(key)
                self.key_to_node[key] = prev_node
            else:
                self._add_node(prev_node, CountNode(new_count, set([key])))
                self.key_to_node[key] = prev_node.next
        else:
            del self.key_to_node[key]

    def getMaxKey(self) -> str:
        max_node = self.tail.prev
        if not max_node.keys:
            return ""
        return next(iter(self.tail.prev.keys))

    def getMinKey(self) -> str:
        min_node = self.head.next
        if not min_node.keys:
            return ""
        return next(iter(min_node.keys))

    def _add_node(self, node, next_node):
        next_node.next = node.next
        next_node.prev = node
        node.next.prev = next_node
        node.next = next_node
    
    def _remove_node(self, node, next_node):
        node.next = next_node.next
        next_node.next.prev = node

