class Solution:
    def numberOfArithmeticSlices(self, nums: List[int]) -> int:
        output: int = 0
        left: int = 0
        for right in range(2, len(nums)):
            if nums[right] - nums[right - 1] != nums[right - 1] - nums[right - 2]: left = right - 1
            if right - left + 1 >= 3: output += (right - 2) - left + 1
        return output
