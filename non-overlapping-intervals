class Solution:
    def eraseOverlapIntervals(self, intervals: List[List[int]]) -> int:
        intervals.sort(key = lambda a : a[1])
        prev_end, count, n = intervals[0][1], 0, len(intervals)
        for i in range(1, n):
            if prev_end > intervals[i][0]:
                count += 1
            else:
                prev_end = intervals[i][1]
        return count
