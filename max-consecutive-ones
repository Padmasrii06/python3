class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        max_count = 0 # assigning max count to be zero
        current_count = 0 # assigning current to be zero

        for num in nums: # for every num in nums
            if num == 1: #if the current num is equal to 1, we increment current_count by 1
                current_count += 1
            else: #if the current num is 0, we find the max count between current max_count and curent_count and reset current_count to 0
                max_count = max(current_count, max_count)
                current_count = 0
        
        max_count = max(current_count, max_count) # finding the max count once again outside the loop 
        return max_count #returning max_count as output
