class MedianFinder:
    def __init__(self):
        self.store = []
    def addNum(self, num: int) -> None:
        self.store.append(num)
    def findMedian(self) -> float:
        self.store.sort()
        n = len(self.store)
        if n % 2 == 1:
            return self.store[n // 2]
        else:
            return (self.store[n // 2 - 1] + self.store[n // 2]) / 2.0

