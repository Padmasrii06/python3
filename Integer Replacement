class Solution:
    def solve(self, n, memo):
        if n == 1:
            return 0
        operations = 0
        if n in memo:
            return memo[n]
        if n % 2 == 0:
            operations = 1 + self.solve(n//2, memo)
        else:
            operations = 1 + min(self.solve(n+1, memo), self.solve(n-1, memo))
        
        memo[n] = operations

        return operations

    def integerReplacement(self, n: int) -> int:
        memo = {}
        return self.solve(n, memo)
