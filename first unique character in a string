from collections import Counter

class Solution:
    def firstUniqChar(self, s: str) -> int:
        # Step 1: Count frequency of each character
        count = Counter(s)
        
        # Step 2: Loop through string to find first unique character
        for c in range(len(s)):
            if count[s[c]] == 1:  # Frequency is exactly 1
                return c  # Return its index
        
        # Step 3: If none found, return -1
        return -1
        
