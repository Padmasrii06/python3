class Solution:
    def lengthOfLIS(self, nums: List[int]) -> int:
        # Array to count the subsequence, initial count 1.
        dp = [1] * len(nums)
        
        # Max length of the longest strictly increasing subsequence. 
        maxLen = 1

        # Empty array case
        if len(nums) == 0:
            return 0

        for i  in range(1, len(nums)):
            for j in range(i):
                if nums[j] < nums[i]:
                    dp[i] = max(dp[i], dp[j] + 1)
            maxLen = max(maxLen, dp[i])

        return maxLen            
